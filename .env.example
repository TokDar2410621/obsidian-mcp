#
# Obsidian MCP Server configuration
#
# Usage:
#   1. Copy this file to .env
#   2. Replace placeholder values with your real credentials and settings
#   3. Keep .env out of version control (already ignored)
#

# Git repository containing your Obsidian vault
# Supports GitHub, GitLab, Bitbucket, and self-hosted git providers
VAULT_REPO=https://github.com/yourusername/your-vault-repo.git

# Branch to deploy (typically main or master)
VAULT_BRANCH=main

# Git Personal Access Token
# Provider is auto-detected from repository URL:
#   - GitHub: Personal Access Token with 'repo' scope (ghp_...)
#   - GitLab: Personal Access Token with 'api' scope (glpat_...)
#   - Bitbucket: App Password with repository read/write
#   - Self-hosted: Personal Access Token or password (also requires GIT_USERNAME)
GIT_TOKEN=your_token_here

# Git username (only required for self-hosted/generic git providers)
# Leave commented out for GitHub, GitLab, or Bitbucket
# GIT_USERNAME=your_username

# Local directory where vault will be cloned (optional)
# Default: ./vault-local (native) or /app/vaults/vault-local (Docker)
# LOCAL_VAULT_PATH=/custom/path/to/vault

# Markdown path template for journal entries (supports {{date}})
JOURNAL_PATH_TEMPLATE=Journal/{{date}}.md

# Date format used when expanding {{date}} in journal paths
JOURNAL_DATE_FORMAT=YYYY-MM-DD

# Heading where automated journal entries are appended
JOURNAL_ACTIVITY_SECTION="## Activity"

# Template file used when creating new journal entries
JOURNAL_FILE_TEMPLATE=Templates/Daily Note.md

# OAuth client configuration shared with your MCP client
OAUTH_CLIENT_ID=obsidian-mcp-client
OAUTH_CLIENT_SECRET=replace_me_with_secret

# Token used to authorize yourself during OAuth registration
PERSONAL_AUTH_TOKEN=replace_me_with_personal_token

# Base URL for the deployed server (update for production)
BASE_URL=http://localhost:3000

# Session lifetime in milliseconds (default: 24 hours)
SESSION_EXPIRY_MS=86400000

# AWS region used for CDK deployment
AWS_REGION=eu-west-1

# --- Semantic RAG (search-cerveau / ask-cerveau) ----------------------------
# All optional. RAG is enabled only when OPENAI_API_KEY is set; otherwise the
# two cerveau tools are simply not registered (existing tools are unaffected).
# HTTP/stdio modes only — not wired into the Lambda build.

# OpenAI API key for embeddings (text-embedding-3-small). Enables search-cerveau.
# OPENAI_API_KEY=sk-...

# Anthropic API key for answer generation. Enables ask-cerveau (full RAG).
# Without it, search-cerveau still works (retrieval only).
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding model (default: text-embedding-3-small)
# RAG_EMBEDDING_MODEL=text-embedding-3-small

# Answer-generation model (default: claude-opus-4-8).
# Set claude-haiku-4-5 or claude-sonnet-4-6 for a cheaper RAG.
# RAG_GENERATION_MODEL=claude-opus-4-8

# Directory for the persisted embedding index. MUST be OUTSIDE the vault clone
# (git clean wipes the vault dir on every sync). Default: ./.rag-index
# (Docker default: /app/index). Mount a Railway volume here to avoid rebuilding
# the index on every redeploy.
# RAG_INDEX_DIR=/app/index

# Shared secret for the GitHub push webhook (POST /webhook/github) that triggers
# an incremental reindex. Without it, the webhook route is disabled.
# GITHUB_WEBHOOK_SECRET=replace_me_with_random_secret

# --- Synapses (thinking layer: suggest-links / audit-coherence / find-themes) -
# Reuses the RAG index to relate notes to each other. Tools register only when
# BOTH OPENAI_API_KEY and ANTHROPIC_API_KEY are set. HTTP/stdio only.

# Model for the Synapses analyses (default: RAG_GENERATION_MODEL, else claude-opus-4-8)
# SYNAPSES_MODEL=claude-opus-4-8

# Weekly digest: writes 00-synapses.md into the vault on a cron. Set "off" to disable.
# SYNAPSES_DIGEST=on

# Cron schedule for the weekly digest (default: Monday 08:00 server time)
# SYNAPSES_CRON=0 8 * * 1
